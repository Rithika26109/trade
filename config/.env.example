# ── Zerodha Kite Connect ──
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_login_password
KITE_TOTP_SECRET=your_totp_secret_here

# ── Telegram Notifications (optional) ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Trading Mode ──
# "paper" = no real money, simulated trades (START HERE)
# "live" = real money, real trades (only after paper testing)
TRADING_MODE=paper
